# Copy this file to .env.local and fill in the Supabase values from
# https://supabase.com/dashboard/project/augbrysfqwgekfhfokco/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://augbrysfqwgekfhfokco.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to require login (redirects unauthed users to /login).
# Leave empty for open dev mode.
NEXT_PUBLIC_REQUIRE_AUTH=

# Team initials used when no one is signed in (dev fallback).
NEXT_PUBLIC_DEFAULT_USER_INITIALS=TZ
